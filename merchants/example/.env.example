# D2C AI Employee — merchant credentials template
# Copy this directory to merchants/<your_merchant_id>/, then fill in .env values.

# =====================================================================
# Shopify
# =====================================================================
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# =====================================================================
# Klaviyo
# =====================================================================
KLAVIYO_PRIVATE_API_KEY=

# =====================================================================
# Razorpay (test mode)
# =====================================================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# =====================================================================
# Anthropic API — OPTIONAL (only for non-Claude-Code runtime)
# =====================================================================
# Leave commented unless running loops outside Claude Code.
# ANTHROPIC_API_KEY=

# =====================================================================
# No tunnel needed — v0 uses polling instead of webhooks
# =====================================================================
# Poll intervals live in config.yaml under `ingestion`.
